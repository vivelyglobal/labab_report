  <script>
    /* ============ shared config ============ */
    const axisColor = "#5c6474";
    const gridColor = "rgba(15,23,42,0.07)";
    const VIOLET = "#8b5cf6";
    const PINK = "#ec4899";
    const MINT = "#10b981";
    const GOLD = "#f59e0b";
    const GRAY = "rgba(15,23,42,0.2)";
    const GRAY2 = "rgba(15,23,42,0.36)";

    Chart.defaults.font.family = '"Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", Arial, sans-serif';
    Chart.defaults.color = axisColor;

    function vGradient(ctx, area, from, to) {
      const g = ctx.createLinearGradient(0, area.bottom, 0, area.top);
      g.addColorStop(0, from);
      g.addColorStop(1, to);
      return g;
    }
    function hGradient(ctx, area, from, to) {
      const g = ctx.createLinearGradient(area.left, 0, area.right, 0);
      g.addColorStop(0, from);
      g.addColorStop(1, to);
      return g;
    }
    const valueLabels = {
      id: "valueLabels",
      afterDatasetsDraw(chart, _, opts) {
        const { ctx } = chart;
        const horizontal = chart.options.indexAxis === "y";
        const fmt = opts.formatter || ((v) => (opts.prefix || "") + Math.round(v).toLocaleString() + (opts.suffix || ""));
        ctx.save();
        ctx.font = "700 12px Pretendard, sans-serif";
        ctx.fillStyle = "#1a1d26";
        chart.data.datasets.forEach((ds, di) => {
          const meta = chart.getDatasetMeta(di);
          if (!meta || meta.hidden) return;
          meta.data.forEach((bar, i) => {
            const text = fmt(ds.data[i]);
            if (horizontal) {
              ctx.textAlign = "left"; ctx.textBaseline = "middle";
              ctx.fillText(text, bar.x + 8, bar.y);
            } else {
              ctx.textAlign = "center"; ctx.textBaseline = "bottom";
              ctx.fillText(text, bar.x, bar.y - 6);
            }
          });
        });
        ctx.restore();
      }
    };
    const logTicks = {
      color: axisColor,
      autoSkip: false,
      callback: (v) => {
        const log = Math.log10(v);
        return Number.isInteger(log) ? v.toLocaleString() : null;
      }
    };

    const charts = {};
    const baseData = {};

    /* 03 — PVV benchmark */
    charts.pvvChart = new Chart(document.getElementById("pvvChart"), {
      type: "bar",
      data: {
        labels: ["시장 최저", "시장 최고", "LaBab x Vively ✦"],
        datasets: [{
          data: [14, 56, 15],
          backgroundColor: (c) => {
            const { ctx, chartArea } = c.chart;
            if (!chartArea) return GRAY;
            if (c.dataIndex === 2) return vGradient(ctx, chartArea, "rgba(16,185,129,0.5)", MINT);
            return vGradient(ctx, chartArea, "rgba(15,23,42,0.1)", GRAY2);
          },
          borderRadius: 8, borderSkipped: false, maxBarThickness: 72
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 1400, easing: "easeOutQuart", delay: (c) => c.dataIndex * 160 },
        plugins: {
          legend: { display: false },
          valueLabels: { prefix: "₩", suffix: "/뷰" },
          tooltip: { callbacks: { label: (ctx) => " ₩" + Math.round(ctx.raw).toLocaleString() + "/뷰" } }
        },
        scales: {
          x: { ticks: { color: axisColor, font: { size: 13, weight: "700" } }, grid: { display: false } },
          y: { ticks: { color: axisColor, callback: (v) => "₩" + v }, grid: { color: gridColor } }
        }
      },
      plugins: [valueLabels]
    });
    baseData.pvvChart = [14, 56, 15];

    /* 04 — regional distribution (creators by region) */
    const REGIONS = [
      { name: "동남아시아", creators: 25, color: [ "rgba(16,185,129,0.5)", MINT ] },
      { name: "남아시아", creators: 16, color: [ "rgba(139,92,246,0.5)", VIOLET ] },
      { name: "유럽", creators: 10, color: [ "rgba(236,72,153,0.4)", PINK ] },
      { name: "러시아 & CIS", creators: 9, color: [ "rgba(245,158,11,0.45)", GOLD ] },
      { name: "아메리카", creators: 6, color: [ "rgba(37,99,235,0.4)", "#2563eb" ] },
      { name: "동아시아", creators: 5, color: [ "rgba(15,23,42,0.12)", GRAY2 ] },
      { name: "중동 & 아프리카", creators: 2, color: [ "rgba(220,38,38,0.4)", "#dc2626" ] }
    ];
    charts.regionChart = new Chart(document.getElementById("regionChart"), {
      type: "bar",
      data: {
        labels: REGIONS.map((r) => r.name),
        datasets: [{
          label: "크리에이터 수",
          data: REGIONS.map((r) => r.creators),
          backgroundColor: (c) => {
            const { ctx, chartArea } = c.chart;
            if (!chartArea) return VIOLET;
            const [a, b] = REGIONS[c.dataIndex].color;
            return hGradient(ctx, chartArea, a, b);
          },
          borderRadius: 8, borderSkipped: false, maxBarThickness: 34
        }]
      },
      options: {
        indexAxis: "y",
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 1400, easing: "easeOutQuart", delay: (c) => c.dataIndex * 120 },
        plugins: {
          legend: { display: false },
          valueLabels: { suffix: "명" },
          tooltip: { callbacks: { label: (ctx) => " " + ctx.raw + "명" } }
        },
        scales: {
          x: { beginAtZero: true, max: 29, ticks: { stepSize: 5, color: axisColor }, grid: { color: gridColor } },
          y: { ticks: { color: axisColor, font: { size: 13, weight: "700" } }, grid: { display: false } }
        }
      },
      plugins: [valueLabels]
    });

    /* 05 — engagement (log scale) */
    charts.engagementChart = new Chart(document.getElementById("engagementChart"), {
      type: "bar",
      data: {
        labels: ["Views", "Shares", "Comments"],
        datasets: [{
          data: [253890, 798, 276],
          backgroundColor: (c) => {
            const { ctx, chartArea } = c.chart;
            if (!chartArea) return VIOLET;
            const pairs = [
              ["rgba(139,92,246,0.45)", VIOLET],
              ["rgba(236,72,153,0.4)", PINK],
              ["rgba(15,23,42,0.12)", GRAY2]
            ];
            const [a, b] = pairs[c.dataIndex];
            return vGradient(ctx, chartArea, a, b);
          },
          borderRadius: 8, borderSkipped: false, maxBarThickness: 84
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 1400, easing: "easeOutQuart", delay: (c) => c.dataIndex * 160 },
        plugins: {
          legend: { display: false },
          valueLabels: {},
          tooltip: { callbacks: { label: (ctx) => " " + Math.round(ctx.raw).toLocaleString() } }
        },
        scales: {
          x: { ticks: { color: axisColor }, grid: { display: false } },
          y: { type: "logarithmic", min: 100, ticks: Object.assign({}, logTicks), grid: { color: gridColor } }
        }
      },
      plugins: [valueLabels]
    });
    baseData.engagementChart = [253890, 798, 276];

    /* 06 — recruitment funnel */
    charts.funnelChart = new Chart(document.getElementById("funnelChart"), {
      type: "bar",
      data: {
        labels: ["지원", "확정", "업로드 완료"],
        datasets: [{
          data: [116, 73, 48],
          backgroundColor: (c) => {
            const { ctx, chartArea } = c.chart;
            if (!chartArea) return VIOLET;
            const pairs = [
              ["rgba(15,23,42,0.12)", GRAY2],
              ["rgba(139,92,246,0.5)", VIOLET],
              ["rgba(16,185,129,0.5)", MINT]
            ];
            const [a, b] = pairs[c.dataIndex];
            return vGradient(ctx, chartArea, a, b);
          },
          borderRadius: 8, borderSkipped: false, maxBarThickness: 84
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 1400, easing: "easeOutQuart", delay: (c) => c.dataIndex * 200 },
        plugins: {
          legend: { display: false },
          valueLabels: { suffix: "명" },
          tooltip: { callbacks: { label: (ctx) => " " + ctx.raw + "명" } }
        },
        scales: {
          x: { ticks: { color: axisColor, font: { size: 13, weight: "700" } }, grid: { display: false } },
          y: { beginAtZero: true, ticks: { color: axisColor }, grid: { color: gridColor } }
        }
      },
      plugins: [valueLabels]
    });

    /* replay chart animation on scroll into view */
    const chartObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const ch = charts[e.target.id];
          if (ch) { ch.reset(); ch.update(); }
        }
      });
    }, { threshold: 0.4 });
    Object.keys(charts).forEach((id) => chartObserver.observe(document.getElementById(id)));

    /* gentle "live breathing" */
    setInterval(() => {
      Object.keys(baseData).forEach((id) => {
        const ch = charts[id];
        ch.data.datasets[0].data = baseData[id].map((v) => v * (1 + (Math.random() - 0.5) * 0.012));
        ch.update({ duration: 1600, easing: "easeInOutSine" });
      });
    }, 2600);

    /* ============ count-up numbers ============ */
    function countUp(el) {
      const target = +el.dataset.target;
      const dur = 1800;
      const start = performance.now();
      function frame(now) {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 4);
        el.textContent = Math.round(target * eased).toLocaleString();
        if (p < 1) requestAnimationFrame(frame);
        else if (el.classList.contains("tick")) startTicker(el, target);
      }
      requestAnimationFrame(frame);
    }
    function startTicker(el, base) {
      let v = base;
      setInterval(() => {
        v += Math.floor(Math.random() * 3) + 1;
        el.textContent = v.toLocaleString();
      }, 2200);
    }
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !e.target.dataset.done) {
          e.target.dataset.done = "1";
          countUp(e.target);
        }
      });
    }, { threshold: 0.6 });
    document.querySelectorAll(".count").forEach((el) => countObserver.observe(el));

    /* ============ reveal on scroll ============ */
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("in"); });
    }, { threshold: 0.12 });
    document.querySelectorAll(".reveal").forEach((el) => revealObserver.observe(el));

    /* ============ reel media slots (labab-1 … labab-4, 9:16) ============ */
    const EXTS = ["mp4", "webm", "gif", "jpg", "png"];
    function tryLoad(slot, name, extIndex) {
      if (extIndex >= EXTS.length) return;
      const ext = EXTS[extIndex];
      const src = "media/" + name + "." + ext;
      if (ext === "mp4" || ext === "webm") {
        const v = document.createElement("video");
        v.muted = true; v.loop = true; v.autoplay = true; v.playsInline = true;
        v.setAttribute("playsinline", "");
        v.addEventListener("loadeddata", () => { slot.classList.add("filled"); v.play().catch(() => {}); });
        v.addEventListener("error", () => { v.remove(); tryLoad(slot, name, extIndex + 1); });
        v.src = src;
        slot.appendChild(v);
      } else {
        const img = document.createElement("img");
        img.alt = name;
        img.addEventListener("load", () => slot.classList.add("filled"));
        img.addEventListener("error", () => { img.remove(); tryLoad(slot, name, extIndex + 1); });
        img.src = src;
        slot.appendChild(img);
      }
    }
    (function () {
      const wrap = document.getElementById("reels-labab");
      for (let i = 1; i <= 4; i++) {
        const name = "labab-" + i;
        const slot = document.createElement("div");
        slot.className = "reel";
        slot.innerHTML =
          '<div class="ico">▶</div>' +
          '<div class="reel-hint">media/' + name + ".mp4<br />파일을 media 폴더에 넣으면 자동 표시</div>" +
          '<span class="ratio-tag">REELS · 1080 × 1920</span>';
        tryLoad(slot, name, 0);
        wrap.appendChild(slot);
      }
    })();
  </script>
